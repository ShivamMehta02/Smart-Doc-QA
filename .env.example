# ── OpenAI ── SET THIS ONCE ─────────────────────
OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-3.5-turbo

# ── App ──────────────────────────────────────────
DEBUG=True
APP_NAME=Smart_Doc_QA

# ── Database ─────────────────────────────────────
# Local dev: postgresql+asyncpg://user:password@localhost:5432/docqa
# Docker: postgresql+asyncpg://user:password@db:5432/docqa
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/docqa

# ── Redis / Celery ──────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
